NODE_ENV=development
PORT=4000

# Firebase Cloud Firestore
# For local development with the Firebase Emulator Suite:
FIREBASE_PROJECT_ID=ltx-office-96354
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# For production, remove FIRESTORE_EMULATOR_HOST and set service account values:
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Local fallback for UI/demo work when Firestore is not available.
# Firebase Auth is still used for login.
# Set false when using Firestore emulator or production Admin credentials.
DEV_LOCAL_DB=true

# The frontend origin is used for CORS.
FRONTEND_URL=https://lumentix.in,http://localhost:3000

# QR verification links are generated as PUBLIC_VERIFY_BASE_URL/{reference_id}.
# Verification links must use the owned lumentix.in domain.
PUBLIC_VERIFY_BASE_URL=https://lumentix.in/verify
REFERENCE_TIMEZONE=Asia/Kolkata

STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=../storage/uploads

# Optional: configure SMTP only if backend email delivery is needed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=bgv@lumentix.in
SMTP_PASS=
SMTP_FROM="LUMENTIX BGV <bgv@lumentix.in>"

S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
